# ── App ────────────────────────────────────────────────────────────────
MCBP_ENV=dev
MCBP_LOG_LEVEL=INFO

# ── 1С / MCBP_AI ───────────────────────────────────────────────────────
MCBP_ONEC_MOCK=true                 # true → працює без 1С (синтетичні дані)
MCBP_ONEC_BASE_URL=http://localhost/base/hs
MCBP_ONEC_USER=
MCBP_ONEC_PASSWORD=
MCBP_ONEC_TIMEOUT_S=30
MCBP_ONEC_POOL_MAX=10

# ── LLM ────────────────────────────────────────────────────────────────
MCBP_LLM_PROVIDER=mock              # mock | anthropic | openai
ANTHROPIC_API_KEY=
MCBP_ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
MCBP_OPENAI_MODEL=gpt-4o
MCBP_LLM_MAX_TOOL_ITERATIONS=8
