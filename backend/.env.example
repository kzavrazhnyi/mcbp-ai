# =============================================================================
# mcbp-ai-backend — шаблон конфігурації
# Скопіюй у backend/.env і заповни значення
# НЕ комітити .env в git!
# =============================================================================

# ---------------------------------------------------------------------------
# Загальне
# ---------------------------------------------------------------------------

# Режим оточення: dev | prod
# prod — CORS закритий, логи стислі
MCBP_ENV=dev

# Рівень логування: DEBUG | INFO | WARNING | ERROR
MCBP_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Підключення до 1С MCBP_AI
# ---------------------------------------------------------------------------

# Базовий URL HTTP-сервісу 1С
# Приклад: http://192.168.1.10/mcbp/hs
MCBP_ONEC_BASE_URL=http://localhost/base/hs

# Ім'я та пароль користувача 1С (HTTP Basic Auth)
MCBP_ONEC_USER=
MCBP_ONEC_PASSWORD=

# Таймаут одного запиту до 1С (секунди)
MCBP_ONEC_TIMEOUT_S=30.0

# Максимум одночасних з'єднань до 1С
MCBP_ONEC_POOL_MAX=10

# Мок-режим: true — реальний 1С не потрібен (для розробки/тестів)
#             false — реальне підключення до 1С
MCBP_ONEC_MOCK=true

# ---------------------------------------------------------------------------
# LLM-провайдер
# ---------------------------------------------------------------------------

# Провайдер: mock | anthropic | openai
# mock — без реального LLM (для розробки)
MCBP_LLM_PROVIDER=mock

# Anthropic (Claude)
ANTHROPIC_API_KEY=
MCBP_ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (GPT-4o) — потрібен лише якщо MCBP_LLM_PROVIDER=openai
OPENAI_API_KEY=
MCBP_OPENAI_MODEL=gpt-4o

# Максимум ітерацій tool-use циклу за один запит
MCBP_LLM_MAX_TOOL_ITERATIONS=8

# ---------------------------------------------------------------------------
# Приклад для продакшну (розкоментуй і заповни)
# ---------------------------------------------------------------------------

# MCBP_ENV=prod
# MCBP_LOG_LEVEL=INFO
# MCBP_ONEC_MOCK=false
# MCBP_ONEC_BASE_URL=http://192.168.1.10/mcbp/hs
# MCBP_ONEC_USER=ai_service
# MCBP_ONEC_PASSWORD=<strong_password>
# MCBP_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
