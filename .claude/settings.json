{
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "65"
  },
  "enabledMcpjsonServers": ["context7"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.crt)",
      "Read(./**/*.p12)",
      "Read(./**/credentials*)",
      "Read(./**/dbconn.php)",
      "Edit(./backend/.venv/**)",
      "Write(./backend/.venv/**)",
      "Edit(./.venv/**)",
      "Write(./.venv/**)",
      "Edit(./bas/**)",
      "Write(./bas/**)",
      "Write(./**/logs/**)"
    ],
    "allow": [
      "Edit(./**)",
      "Write(./**)",
      "MultiEdit(./**)",
      "PowerShell(New-Item:*)",
      "PowerShell(Set-Content:*)",
      "PowerShell(Add-Content:*)",
      "PowerShell(Out-File:*)",
      "PowerShell(Out-Null)",
      "PowerShell(Write-Host:*)",
      "PowerShell(Write-Output:*)",
      "PowerShell(Copy-Item:*)",
      "PowerShell(Move-Item:*)",
      "PowerShell(Remove-Item:*)",
      "PowerShell(Rename-Item:*)",
      "PowerShell(Clear-Content:*)",
      "PowerShell(Start-Process:*)",
      "PowerShell(Stop-Process:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Get-Item:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(Select-String:*)",
      "PowerShell(Resolve-Path:*)",
      "PowerShell(Measure-Object:*)",
      "PowerShell(ForEach-Object:*)",
      "PowerShell(Where-Object:*)",
      "PowerShell(Select-Object:*)",
      "PowerShell(Sort-Object:*)",
      "PowerShell(Format-List:*)",
      "PowerShell(Format-Table:*)",
      "PowerShell(Get-FileHash:*)",
      "PowerShell(Join-Path:*)",
      "PowerShell(Split-Path:*)",
      "PowerShell(Compare-Object:*)",
      "PowerShell(Group-Object:*)",
      "Bash(powershell -NoProfile -File:*)",
      "Bash(powershell -NoProfile -ExecutionPolicy Bypass -File:*)",
      "Bash(powershell -File:*)",
      "Bash(pwsh -NoProfile -File:*)",
      "Bash(pwsh -NoProfile -ExecutionPolicy Bypass -File:*)",
      "Bash(pwsh -File:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(python -m py_compile:*)",
      "Bash(ruff check --no-fix:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:context7.com)",
      "WebFetch(domain:github.com)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$f = $env:CLAUDE_TOOL_FILE_PATH; if ($f -and ($f -like '*.py')) { python -m py_compile $f }\"",
            "statusMessage": "py_compile on changed file"
          }
        ]
      }
    ]
  }
}
