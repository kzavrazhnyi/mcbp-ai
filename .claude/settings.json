{
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "65"
  },
  "enabledMcpjsonServers": ["context7"],
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.crt)",
      "Read(./**/*.p12)",
      "Read(./**/credentials*)",
      "Read(./**/dbconn.php)",
      "Edit(./backend/.venv/**)",
      "Write(./backend/.venv/**)",
      "Edit(./.venv/**)",
      "Write(./.venv/**)",
      "Edit(./bas/**)",
      "Write(./bas/**)",
      "Write(./**/logs/**)"
    ],
    "allow": [
      "Edit(./**)",
      "Write(./**)",
      "MultiEdit(./**)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(ln -s:*)",
      "Bash(ln -sf:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(which:*)",
      "Bash(bash ./.scripts/:*)",
      "Bash(bash ./.scripts/*.sh)",
      "Bash(brew --version)",
      "Bash(brew --prefix:*)",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(uv run:*)",
      "Bash(uv venv:*)",
      "Bash(uv python list:*)",
      "Bash(uv python pin:*)",
      "Bash(python3.11 -m py_compile:*)",
      "Bash(python3.12 -m py_compile:*)",
      "Bash(python3.13 -m py_compile:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(python -m py_compile:*)",
      "Bash(ruff check --no-fix:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:context7.com)",
      "WebFetch(domain:github.com)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"$CLAUDE_TOOL_FILE_PATH\"; case \"$f\" in *.py) uv run python -m py_compile \"$f\" ;; esac",
            "statusMessage": "py_compile on changed file"
          }
        ]
      }
    ]
  }
}
